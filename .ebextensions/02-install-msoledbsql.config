files:
  "C:\\sqldriver\\install-msoledbsql.ps1":
    content: |
      $ErrorActionPreference = "Stop"

      $dir = "C:\sqldriver\"
      if (!(Test-Path $dir)) { New-Item -ItemType Directory -Path $dir -Force | Out-Null }
      $installerFile = "msoledbsql.msi"
      $installerPath = Join-Path $dir $installerFile
      $downloadUrl = "https://go.microsoft.com/fwlink/?linkid=2364027"
      $logFile = "C:\sqldriver\msoledbsql-install.log"

      Write-Host "Downloading Microsoft OLE DB Driver for SQL Server (x64) to $installerPath"
      [Net.ServicePointManager]::SecurityProtocol = [Net.SecurityProtocolType]::Tls12
      $webClient = New-Object System.Net.WebClient
      $webClient.DownloadFile($downloadUrl, $installerPath)

      if (!(Test-Path $installerPath)) {
          throw "Download failed - installer not found at $installerPath"
      }

      Write-Host "Installer downloaded. Size: $((Get-Item $installerPath).Length) bytes"
      Write-Host "Running as user: $([System.Security.Principal.WindowsIdentity]::GetCurrent().Name)"
      Write-Host "Installing Microsoft OLE DB Driver for SQL Server..."

      $process = Start-Process -FilePath "msiexec.exe" `
          -ArgumentList "/i `"$installerPath`" /quiet /norestart /log `"$logFile`" IACCEPTMSOLEDBSQLLICENSETERMS=YES" `
          -Wait -PassThru -NoNewWindow

      Write-Host "Installer exited with code: $($process.ExitCode)"

      if (Test-Path $logFile) {
          Write-Host "--- Installer log tail ---"
          Get-Content $logFile -Tail 20 | ForEach-Object { Write-Host $_ }
          Write-Host "--- End installer log ---"
      } else {
          Write-Host "WARNING: No installer log file created at $logFile"
      }

      if ($process.ExitCode -ne 0) {
          throw "Microsoft OLE DB Driver installer failed with exit code $($process.ExitCode)"
      }

      Write-Host "Microsoft OLE DB Driver for SQL Server installation complete"

commands:
  01_install_msoledbsql:
    command: powershell.exe -ExecutionPolicy Bypass -File "C:\sqldriver\install-msoledbsql.ps1"
    waitAfterCompletion: 300
    ignoreErrors: true
